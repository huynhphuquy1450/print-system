{
  "name": "print-system",
  "version": "1.0.0",
  "private": true,
  "description": "Print System monorepo (server + agent)",
  "scripts": {
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write \"**/*.{js,json,md}\" --ignore-path .gitignore",
    "lint:server": "cd server && npm run lint",
    "lint:agent": "cd agent && npm run lint"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.2"
  }
}
