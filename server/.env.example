# Print Service - Environment template
# Copy to .env và điền giá trị thật

NODE_ENV=production
PORT=3000

# Database (PostgreSQL — preferred)
DATABASE_URL=postgres://user:password@localhost:5432/printservice
DB_BACKUPS_DIR=./data/backups
DB_BACKUP_RETENTION_DAYS=30

# Storage
STORAGE_PATH=./storage
STORAGE_RETENTION_DAYS=7

# Audit log retention (purge dòng audit_log cũ hơn N ngày, chạy lúc CLEANUP_HOUR)
AUDIT_RETENTION_DAYS=90

# MQTT (TLS)
MQTT_URL=mqtts://160.250.133.192:8883
MQTT_USER=printservice
MQTT_PASS=CHANGE_ME
MQTT_CA_FILE=/etc/mosquitto/certs/server.crt
MQTT_REJECT_UNAUTHORIZED=true
MQTT_TOPIC_PREFIX=company/printer
MQTT_CLIENT_ID=print-service-1

# JWT
JWT_SECRET=CHANGE_ME_48_chars_random
JWT_EXPIRES_IN=7d

# Agent token hash
AGENT_TOKEN_SECRET=CHANGE_ME_48_chars_random

# Cron
RETRY_INTERVAL_MIN=5
STALE_JOB_MIN=5
MAX_RETRIES=5
CLEANUP_HOUR=3
BACKUP_HOUR=2

# Rate limit (login)
AUTH_LOGIN_RATE_PER_MIN=5

# Rate limit (per-client write: POST jobs/branches/printers/agents)
CLIENT_WRITE_RATE_PER_MIN=30

# Rate limit (self-service branch registration)
SETUP_REGISTER_RATE_PER_HOUR=5

# Redis (tùy chọn): set để rate-limit chia sẻ counter giữa nhiều node (scale ngang).
# Không set → dùng bộ đếm in-process (đủ cho single-server).
# REDIS_URL=redis://localhost:6379

# Webhook allowlist (tùy chọn, opt-in): CSV domain ERP được phép nhận callback.
# Khớp exact host hoặc subdomain (vd "erp.acme.com" cho cả "api.erp.acme.com").
# Không set → tắt allowlist (vẫn luôn chặn IP nội bộ qua SSRF guard).
# WEBHOOK_ALLOWED_HOSTS=erp.acme.com,hooks.partner.io

# Public URL of this server (used in install JSON, defaults to http://localhost:$PORT)
# SERVER_PUBLIC_URL=https://print.example.com

# HTTPS — for agents accessing the API over the public internet.
# When enabled, an additional https.createServer binds to HTTPS_PORT (default 443)
# using cert/key from disk. HTTP (PORT=3000) is always bound for HQ LAN access.
# Certs are typically issued by Step-CA (see scripts/setup-step-ca.sh).
# Set HTTPS_ENABLED=true in production once certs are provisioned.
HTTPS_ENABLED=false
HTTPS_PORT=443
HTTPS_CERT_FILE=./certs/server.crt
HTTPS_KEY_FILE=./certs/server.key