{
  "name": "print-service",
  "version": "1.0.0",
  "description": "Print Service - In PDF hợp đồng từ xa qua MQTT",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "gen:client": "node scripts/gen-client.js",
    "gen:agents": "node scripts/gen-agents.js",
    "test:health": "node scripts/health-check.js",
    "test": "jest",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write \"**/*.{js,json,md}\" --ignore-path .gitignore"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFiles": [
      "<rootDir>/jest.setup.js"
    ],
    "testMatch": [
      "<rootDir>/src/**/__tests__/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/services/*.js",
      "!src/services/__tests__/**"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 30,
        "statements": 30
      }
    },
    "verbose": true
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.3.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mqtt": "^5.10.1",
    "multer": "^1.4.5-LTS",
    "uuid": "^10.0.0",
    "winston": "^3.13.1",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "prettier": "^3.3.2"
  }
}
