# Print Agent - Environment template
# Copy to .env and fill in real values from your team's secret manager (Bitwarden/1Password)

# === Identity (from install.json after --register) ===
BRANCH_ID=br_001
AGENT_TOKEN=<paste_from_secret_manager>

# === MQTT (TLS — uses Step-CA-issued cert on server) ===
# The server's MQTT broker (port 8883) is now signed by our internal CA.
# You must install the root_ca.crt (from HQ IT) into the Windows Trusted
# Root Certification Authorities store, then point MQTT_CA_FILE at it.
# See CA_INSTALL.md for step-by-step instructions.
MQTT_URL=mqtts://160.250.133.192:8883
MQTT_USER=printservice
MQTT_PASS=<mqtt_pass>
MQTT_CA_FILE=C:\print-system\root_ca.crt

# === API (HTTPS for internet-bound traffic) ===
# The print service exposes the same Express app on both HTTP (3000, for
# HQ LAN) and HTTPS (443, for internet agents). Agents always use HTTPS so
# download payloads and auth headers are encrypted in transit.
API_URL=https://160.250.133.192:443

# === SumatraPDF ===
SUMATRA_PATH=C:\print-system\tools\SumatraPDF.exe
TMP_DIR=C:\print-system\agents\agent-01\tmp
LOG_DIR=C:\print-system\agents\agent-01\logs
# PRINTER_NAME=  (empty = default printer)

# Optional: force paper size + fit-to-page for SumatraPDF
# Format: "<from_page>,<paper>,<scaling>"
# Examples: "1,a4,fit" | "1,a5,fit" | "1,letter,shrink"
PRINT_SETTINGS=1,a4,fit

# === TLS validation ===
# Keep MQTT_REJECT_UNAUTHORIZED at default (true) — the cert is signed by
# our CA, so strict validation works. DO NOT set to false.
# (The MQTT client in mqtt@^5.10.1 defaults to rejectUnauthorized=true;
# uncomment below only for emergency debugging — will print a clear warning.)
# MQTT_REJECT_UNAUTHORIZED=false