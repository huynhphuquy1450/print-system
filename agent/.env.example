# Print Agent - Environment template
# Copy to .env and fill in real values from your team's secret manager (Bitwarden/1Password)

# === Identity (from install.json after --register) ===
# BRANCH_ID: KHÔNG set tay — `node agent.js --register install.json` tự điền dòng này
# (và AGENT_TOKEN bên dưới) sau khi đăng ký branch thành công. Để trống ở template.
BRANCH_ID=
AGENT_TOKEN=<paste_from_secret_manager>

# === MQTT (TLS) ===
# Deployment mặc định: broker MQTT (port 8883) dùng cert TỰ KÝ (self-signed), KHÔNG phải Step-CA.
# `root_ca.crt` trong trường hợp này chính là cert của broker (HQ export từ server, xem CA_INSTALL.md).
# Bạn vẫn cần cài/point vào root_ca.crt để agent trust được kết nối MQTTS.
# Nếu deployment của bạn dùng Step-CA (PKI nội bộ) thay vì self-signed thì luồng cài đặt tương tự,
# chỉ khác nguồn gốc cert — vẫn theo CA_INSTALL.md.
MQTT_URL=mqtts://<SERVER_IP>:8883
MQTT_USER=printservice
MQTT_PASS=<mqtt_pass>
MQTT_CA_FILE=C:\print-system\root_ca.crt
# Topic prefix khớp server (config.mqtt.topicPrefix). `--register` tự ghi từ server; chỉ set tay khi
# HQ đổi prefix khác mặc định.
# MQTT_TOPIC_PREFIX=company/printer

# === API ===
# Mặc định server chạy API trên HTTP:3000 (HTTPS_ENABLED=false ở server/.env) — dùng luồng HTTP bên
# dưới trừ khi HQ đã bật HTTPS_ENABLED=true + cấp cert nội bộ cho print-service (khi đó đổi sang
# https://<SERVER_IP>:443 và agent cần root_ca.crt cho cả API, không chỉ MQTT).
# Node KHÔNG đọc Windows cert store: agent tự nạp CA từ MQTT_CA_FILE (root_ca.crt) cho axios, nên
# nếu API chạy HTTPS với cert nội bộ, kết nối vẫn verify được — không cần NODE_EXTRA_CA_CERTS.
API_URL=http://<SERVER_IP>:3000
# API_URL=https://<SERVER_IP>:443   # chỉ dùng khi server đã bật HTTPS_ENABLED=true

# === SumatraPDF ===
SUMATRA_PATH=C:\print-system\tools\SumatraPDF.exe
TMP_DIR=C:\print-system\agents\agent-01\tmp
LOG_DIR=C:\print-system\agents\agent-01\logs
# PRINTER_NAME=  (empty = default printer)

# Optional: force paper size + fit-to-page for SumatraPDF
# Format: "<from_page>,<paper>,<scaling>"
# Examples: "1,a4,fit" | "1,a5,fit" | "1,letter,shrink"
PRINT_SETTINGS=1,a4,fit

# === Fallback poll (lưới an toàn khi MQTT sập) ===
# Agent poll GET /api/print-jobs mỗi POLL_INTERVAL giây, ĐỘC LẬP với MQTT.
# Khi MQTT khỏe, job vẫn về tức thì qua push; poll chỉ là lưới nền. Mặc định 15s.
POLL_INTERVAL=15

# === TLS validation ===
# Keep MQTT_REJECT_UNAUTHORIZED at default (true) — the cert is signed by
# our CA, so strict validation works. DO NOT set to false.
# (The MQTT client in mqtt@^5.10.1 defaults to rejectUnauthorized=true;
# uncomment below only for emergency debugging — will print a clear warning.)
# MQTT_REJECT_UNAUTHORIZED=false